    <div style="max-width: 860px; margin: 0 auto;">
        {{> section-header label="YouTube" title="Quer me ver construindo?" action_href="https://www.youtube.com/@gabrielmaciel17" action_label="Ver canal →"}}

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
            <div class="fade-in" data-delay="0">
                <a href="https://www.youtube.com/watch?v=P8jVlOAN1Mg" target="_blank" rel="noopener noreferrer" style="text-decoration: none; display: block;">
                    <div class="card yt-card">
                        <div style="position: relative; aspect-ratio: 16/9; overflow: hidden; background: #DDE4E8;">
                            <img src="https://img.youtube.com/vi/P8jVlOAN1Mg/hqdefault.jpg" alt="Como Criar uma IA Geradora de Prompts? (100% Gratuito)" width="480" height="360" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy">
                            <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.22); display: flex; align-items: center; justify-content: center;">
