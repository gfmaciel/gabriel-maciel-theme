{{!-- ── CONTATO ── --}}
<section id="contato" class="section" style="background: #0C2D3E; position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; opacity: 0.04; background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px; pointer-events: none;"></div>
    <div style="max-width: 860px; margin: 0 auto; position: relative;">

        <div class="fade-in" style="text-align: center; margin-bottom: 44px;">
            <div class="sans" style="font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #D4A920; margin-bottom: 8px;">Vamos trabalhar juntos</div>
            <div style="width: 44px; height: 3px; background: #D4A920; border-radius: 2px; margin: 0 auto 16px;"></div>
            <h2 class="serif" style="font-size: clamp(26px, 4vw, 42px); font-weight: 700; color: #FFFFFF; line-height: 1.1; margin-bottom: 12px;">Como posso te ajudar?</h2>
        </div>

        {{!-- Step 1: Service selection --}}
        <div class="sans" style="display: flex; align-items: center; gap: 10px; margin-bottom: 14px;">
            <div style="width: 24px; height: 24px; border-radius: 50%; background: #D4A920; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; color: #0C2D3E; flex-shrink: 0;">1</div>
            <span style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.07em;">O que você precisa?</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 44px;">
            <button class="service-option"
                data-key="consultoria"
                data-template="Olá Gabriel, tenho uma [tipo de empresa/área] e hoje perdemos [tempo/dinheiro/recurso] com [processo específico]. Quero entender se consigo resolver isso com IA sem precisar de uma equipe técnica. Você consegue me ajudar?">
                <div class="service-radio" style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; transition: border-color 0.2s;">
                    <div class="service-radio-dot" style="width: 10px; height: 10px; border-radius: 50%; background: #D4A920; display: none;"></div>
                </div>
                <div style="flex: 1;">
                    <div class="service-label sans" style="font-size: 15px; font-weight: 600; color: #FFFFFF; margin-bottom: 3px; transition: color 0.2s;">Entender como aplicar IA no meu negócio</div>
                    <div class="sans" style="font-size: 13px; color: rgba(255,255,255,0.38); line-height: 1.5;">Mapeio onde a IA pode gerar resultado real para você — sem promessas vazias.</div>
                </div>
                <span style="font-size: 20px; flex-shrink: 0;">🔍</span>
            </button>

            <button class="service-option"
                data-key="desenvolvimento"
                data-template="Olá Gabriel, preciso automatizar [processo específico] na minha empresa. Hoje fazemos isso manualmente e leva [tempo/custo aproximado]. Quero saber se você consegue construir uma solução para isso.">
                <div class="service-radio" style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; transition: border-color 0.2s;">
                    <div class="service-radio-dot" style="width: 10px; height: 10px; border-radius: 50%; background: #D4A920; display: none;"></div>
                </div>
                <div style="flex: 1;">
                    <div class="service-label sans" style="font-size: 15px; font-weight: 600; color: #FFFFFF; margin-bottom: 3px; transition: color 0.2s;">Desenvolver uma solução de IA para mim</div>
                    <div class="sans" style="font-size: 13px; color: rgba(255,255,255,0.38); line-height: 1.5;">Construo soluções personalizadas com IA para automatizar processos ou criar novos produtos.</div>
                </div>
                <span style="font-size: 20px; flex-shrink: 0;">🛠️</span>
            </button>

            <button class="service-option"
                data-key="treinamento"
                data-template="Olá Gabriel, tenho um time de [tamanho] pessoas em [área/setor] e quero que eles usem IA para [objetivo]. O maior obstáculo hoje é [barreira principal]. Podemos conversar sobre um treinamento?">
                <div class="service-radio" style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; transition: border-color 0.2s;">
                    <div class="service-radio-dot" style="width: 10px; height: 10px; border-radius: 50%; background: #D4A920; display: none;"></div>
                </div>
                <div style="flex: 1;">
                    <div class="service-label sans" style="font-size: 15px; font-weight: 600; color: #FFFFFF; margin-bottom: 3px; transition: color 0.2s;">Treinar meu time a ser mais produtivo com IA</div>
                    <div class="sans" style="font-size: 13px; color: rgba(255,255,255,0.38); line-height: 1.5;">Ensino times a usar ferramentas de IA no dia a dia, de forma prática e sem jargão técnico.</div>
                </div>
                <span style="font-size: 20px; flex-shrink: 0;">🎓</span>
            </button>
        </div>

        <div style="height: 1px; background: rgba(255,255,255,0.07); margin-bottom: 40px;"></div>

        {{!-- Step 2: Form --}}
        <div id="form-section">
            <div class="sans" style="display: flex; align-items: center; gap: 10px; margin-bottom: 28px;">
                <div id="step2-indicator" style="width: 24px; height: 24px; border-radius: 50%; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; color: rgba(255,255,255,0.4); flex-shrink: 0; transition: background 0.3s, color 0.3s;">2</div>
                <span id="step2-label" class="sans" style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.22); text-transform: uppercase; letter-spacing: 0.07em; transition: color 0.3s;">Seus dados</span>
            </div>

            <div class="contact-grid" style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 48px; align-items: start;">
                {{!-- Left: contact info --}}
                <div>
                    <h3 class="serif" style="font-size: 20px; font-weight: 700; color: #FFFFFF; margin-bottom: 10px;">Me manda uma mensagem</h3>
                    <p class="sans" style="font-size: 14px; line-height: 1.75; color: rgba(255,255,255,0.4); margin-bottom: 24px;">Você também pode me escrever diretamente:</p>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        <div class="contact-chip">
                            <div style="width: 32px; height: 32px; border-radius: 6px; background: rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.55)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                            </div>
                            <div>
                                <div class="sans" style="font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #D4A920; margin-bottom: 2px;">Email</div>
                                <div class="sans" style="font-size: 13px; color: rgba(255,255,255,0.38);">contato@gabrielmaciel.com.br</div>
                            </div>
                        </div>
                        <div class="contact-chip">
                            <div style="width: 32px; height: 32px; border-radius: 6px; background: #0A66C2; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                            </div>
                            <div>
                                <div class="sans" style="font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #D4A920; margin-bottom: 2px;">LinkedIn</div>
                                <div class="sans" style="font-size: 13px; color: rgba(255,255,255,0.38);">linkedin.com/in/gfmaciel</div>
                            </div>
                        </div>
                    </div>
                </div>

                {{!-- Right: form --}}
                <div>
                    <div id="contact-success" style="display: none; background: #163B50; border: 2px solid #D4A920; border-radius: 12px; padding: 40px; text-align: center;">
                        <div style="font-size: 44px; margin-bottom: 14px;">✅</div>
                        <h3 class="serif" style="font-size: 22px; font-weight: 700; color: #FFFFFF; margin-bottom: 8px;">Mensagem enviada!</h3>
                        <p class="sans" style="font-size: 14px; color: rgba(255,255,255,0.45);">Obrigado. Vou te responder em breve.</p>
                    </div>

                    <form id="contact-form" novalidate style="display: flex; flex-direction: column; gap: 14px;">
                        <div class="float-field" data-field="nome">
                            <input type="text" id="nome" name="nome" autocomplete="name">
                            <label for="nome">Seu nome</label>
                        </div>
                        <div class="float-field" data-field="email">
                            <input type="email" id="email" name="email" autocomplete="email">
                            <label for="email">Seu email</label>
                        </div>
                        <div class="float-field" data-field="mensagem">
                            <textarea id="mensagem" name="mensagem" rows="5" data-maxlen="600"></textarea>
                            <label for="mensagem">Mensagem</label>
                        </div>

                        <div id="template-hint" class="sans" style="display: none; font-size: 12px; color: rgba(255,255,255,0.3); line-height: 1.5; margin-top: -4px;">
                            💡 Preencha os campos entre [ ] com as informações do seu negócio.
                        </div>

                        {{!-- reCAPTCHA v3 — invisible, no widget needed.
                             Site key is injected via Ghost Code Injection (Site Header):
                             <script>window.RECAPTCHA_SITE_KEY = "YOUR_V3_SITE_KEY";</script>
                             Token is obtained on submit via grecaptcha.execute() in main.js --}}

                        <button type="submit" id="contact-submit" class="btn-gold" style="align-self: flex-start; display: flex; align-items: center; gap: 8px;">
                            Enviar mensagem →
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</section>

{{!-- reCAPTCHA v3: lazy-loaded when #contato section enters viewport to avoid blocking initial render --}}
<script>
(function() {
    var loaded = false;
    var observer = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && !loaded) {
            loaded = true;
            var siteKey = window.RECAPTCHA_SITE_KEY || '';
            if (!siteKey) return;
            var s = document.createElement('script');
            s.src = 'https://www.google.com/recaptcha/enterprise.js?render=' + siteKey;
            s.async = true;
            document.head.appendChild(s);
            observer.disconnect();
        }
    }, { rootMargin: '200px' });
    var target = document.getElementById('contato');
    if (target) observer.observe(target);
})();
</script>
