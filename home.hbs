{{!< default}}

{{!-- ── HERO ── --}}
<section class="hero-section" style="background: #0C2D3E; position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; right: 0; width: 260px; height: 260px; opacity: 0.05; background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 20px 20px; pointer-events: none;"></div>
    <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, #D4A920, transparent);"></div>

    <div style="max-width: 760px; margin: 0;">
        <div class="fade-in" data-delay="0.1" style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px;">
            <span style="font-size: 18px;">👋</span>
            <span class="sans" style="font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.5); letter-spacing: 0.1em; text-transform: uppercase;">Olá, meu nome é</span>
        </div>
        <h1 class="serif fade-in" data-delay="0.22" style="font-size: clamp(52px, 10vw, 96px); font-weight: 700; line-height: 0.93; letter-spacing: -0.025em; color: #FFFFFF; margin-bottom: 32px;">
            Gabriel<br><span style="color: #D4A920;">Maciel.</span>
        </h1>
        <p class="sans fade-in" data-delay="0.38" style="font-size: clamp(18px, 2.4vw, 22px); font-weight: 300; line-height: 1.55; color: rgba(255,255,255,0.88); margin-bottom: 14px; max-width: 520px;">
            Você não precisa entender de tecnologia
            <em class="serif" style="font-style: italic; font-weight: 700; color: #FFFFFF;">para usar IA de verdade.</em>
        </p>
        <p class="sans fade-in" data-delay="0.48" style="font-size: clamp(15px, 1.8vw, 17px); font-weight: 300; line-height: 1.7; color: rgba(255,255,255,0.62); margin-bottom: 40px; max-width: 480px;">
            Construo automações e ferramentas de IA — e documento cada passo aqui para você replicar no seu negócio.
        </p>
        <div class="hero-ctas fade-in" data-delay="0.56" style="display: flex; gap: 14px; flex-wrap: wrap;">
            <a href="/projetos/" class="btn-gold" style="text-decoration: none;">Conhecer projetos</a>
            <a href="#contato" class="btn-outline" style="text-decoration: none;">Trabalhe comigo</a>
        </div>
    </div>

    {{!-- Scroll cue --}}
    <a href="#projetos" class="sans" style="position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 6px; color: rgba(255,255,255,0.35); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: color 0.2s;" aria-label="Ver mais">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation: scrollBounce 2s ease-in-out infinite;"><polyline points="6 9 12 15 18 9"/></svg>
    </a>
</section>

{{!-- ── PROJETOS ── --}}
<section id="projetos" class="section" style="background: #F7F8F9; border-bottom: 1px solid #DDE4E8;">
    <div style="max-width: 860px; margin: 0 auto;">
        {{> section-header label="Projetos" title="O que estou construindo" action_href="/projetos/" action_label="Ver todos →"}}

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px;">
            {{#get "posts" filter="tag:hash-projetos" limit="3"}}
                {{#foreach posts}}
                <div class="fade-in">
                    <a href="{{url}}" style="text-decoration: none; display: block; height: 100%;">
                        <div class="card" style="height: 100%; display: flex; flex-direction: column;">
                            <div style="padding: 24px; display: flex; flex-direction: column; flex: 1;">
                                {{#if feature_image}}
                                <div style="font-size: 32px; margin-bottom: 12px;">
                                    <img src="{{img_url feature_image size='xs' format='webp'}}" alt="{{title}}" width="100" height="100" style="width: 40px; height: 40px; object-fit: contain; border-radius: 4px;">
                                </div>
                                {{else}}
                                <div style="font-size: 32px; margin-bottom: 12px;">🚀</div>
                                {{/if}}
                                {{#if primary_tag}}<div style="margin-bottom: 10px;"><span class="pill">{{primary_tag.name}}</span></div>{{/if}}
                                <h3 class="serif" style="font-size: 19px; font-weight: 700; margin-bottom: 10px; line-height: 1.25; color: #0C2D3E;">{{title}}</h3>
                                <p class="sans" style="font-size: 14px; line-height: 1.7; color: #3A4A56; flex: 1;">{{excerpt words="20"}}</p>
                            </div>
                        </div>
                    </a>
                </div>
                {{/foreach}}
            {{else}}
                {{!-- Fallback: no projects tagged yet --}}
                <div class="card" style="padding: 24px; grid-column: 1/-1; text-align: center; color: #6B7E8C;">
                    <p class="sans" style="font-size: 14px;">Em breve — projetos sendo adicionados.</p>
                </div>
            {{/get}}
        </div>
    </div>
</section>

{{!-- ── ARTIGOS ── --}}
<section id="artigos" class="section" style="background: #FFFFFF;">
    <div style="max-width: 860px; margin: 0 auto;">
        {{> section-header label="Artigos" title="O que escrevo" action_href="/posts/" action_label="Ver todos →"}}

        <div>
            {{#get "posts" filter="visibility:public+tag:-hash-projetos" limit="4"}}
                {{#foreach posts}}
                <div class="fade-in">
                    {{> post-card}}
                </div>
                {{/foreach}}
            {{else}}
                <p class="sans" style="font-size: 14px; color: #6B7E8C;">Nenhum artigo publicado ainda.</p>
            {{/get}}
        </div>
    </div>
</section>

{{!-- ── YOUTUBE ── --}}
