{{!< default}}

{{!-- Generic static page fallback --}}
{{#post}}

{{#match @page.show_title_and_feature_image}}
<section style="background: #0C2D3E; padding: 80px 32px 64px;">
    <div style="max-width: 760px; margin: 0 auto;">
        {{#if primary_tag}}
        <div class="sans" style="font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #D4A920; margin-bottom: 10px;">{{primary_tag.name}}</div>
        {{/if}}
        <div style="width: 44px; height: 3px; background: #D4A920; border-radius: 2px; margin-bottom: 20px;"></div>
        <h1 class="serif" style="font-size: clamp(32px, 6vw, 56px); font-weight: 700; color: #FFFFFF; line-height: 1.1;">{{title}}</h1>
        {{#if custom_excerpt}}
        <p class="sans" style="font-size: 17px; color: rgba(255,255,255,0.6); max-width: 520px; margin-top: 14px; line-height: 1.6;">{{custom_excerpt}}</p>
        {{/if}}
    </div>
</section>

{{#if feature_image}}
<div style="max-height: 400px; overflow: hidden;">
    <img src="{{img_url feature_image size='l'}}" alt="{{title}}" style="width: 100%; object-fit: cover; display: block;">
</div>
{{/if}}
{{/match}}

<article style="max-width: 720px; margin: 0 auto; padding: 56px 32px;">
    <div class="post-content">
        {{{content}}}
    </div>
    <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid #DDE4E8;">
        <a href="{{@site.url}}" class="sans" style="font-size: 14px; font-weight: 600; color: #0C2D3E; text-decoration: none; border-bottom: 2px solid #D4A920; padding-bottom: 2px;">← Voltar para o início</a>
    </div>
</article>

{{/post}}
