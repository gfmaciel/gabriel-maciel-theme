<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="canonical" href="{{canonical_url}}">

    {{!-- Theme stylesheet --}}
    <link rel="stylesheet" type="text/css" href="{{asset 'css/screen.css'}}">

    {{!-- Preconnect for external resources --}}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">

    {{!-- Ensure fade-in content is visible when JS is disabled --}}
    <noscript><style>.fade-in { opacity: 1 !important; transform: none !important; }</style></noscript>

    {{!-- Ghost head (SEO, structured data, members) - MUST be last in <head> --}}
    {{ghost_head}}
</head>
<body class="{{body_class}}">

    {{> navigation}}

    <div class="mobile-menu" id="mobile-menu">
        <a href="{{@site.url}}/posts/">Artigos</a>
        <a href="/projetos/">Projetos</a>
        <a href="/#contato" style="color: #D4A920; font-weight: 700;">Fale comigo →</a>
    </div>

    <main id="site-main">
        {{{body}}}
    </main>

    {{> footer}}

    {{!-- Theme JS --}}
    <script src="{{asset 'js/main.js'}}" defer></script>

    {{!-- Ghost foot (portal, search, etc.) - MUST be before </body> --}}
    {{ghost_foot}}
</body>
</html>
