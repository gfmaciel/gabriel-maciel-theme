<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="canonical" href="{{canonical_url}}">
    <meta name="description" content="{{meta_description}}">

    {{!-- Open Graph --}}
    <meta property="og:site_name" content="{{@site.title}}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{meta_title}}">
    <meta property="og:description" content="{{meta_description}}">
    {{#if @site.cover_image}}
    <meta property="og:image" content="{{img_url @site.cover_image size='xl'}}">
    {{/if}}

    {{!-- Twitter Card --}}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{meta_title}}">
    <meta name="twitter:description" content="{{meta_description}}">

    {{!-- Theme stylesheet --}}
    <link rel="stylesheet" type="text/css" href="{{asset 'css/screen.css'}}">

    {{!-- reCAPTCHA - loaded async, rendered on demand by main.js --}}
    <script src="https://www.google.com/recaptcha/api.js?onload=onRecaptchaLoad&render=explicit" async defer></script>

    {{!-- Ghost head (SEO, structured data, members) - MUST be last in <head> --}}
    {{ghost_head}}
</head>
<body class="{{body_class}}">

    {{> navigation}}

    <div class="mobile-menu">
        <a href="{{@site.url}}/posts/">Artigos</a>
        <a href="/projetos/">Projetos</a>
        <a href="/#contato" style="color: #D4A920; font-weight: 700;">Fale comigo →</a>
    </div>

    <main id="site-main">
        {{{body}}}
    </main>

    {{> footer}}

    {{!-- Theme JS --}}
    <script src="{{asset 'js/main.js'}}"></script>

    {{!-- Ghost foot (portal, search, etc.) - MUST be before </body> --}}
    {{ghost_foot}}
</body>
</html>
