{{!-- Post card partial: cover-image card if feature_image exists, else text row --}}
{{#if feature_image}}
<a href="{{url}}" class="card blog-cover-card" style="display: flex; overflow: hidden; text-decoration: none; color: inherit; margin-bottom: 16px;">
    <div class="blog-cover-img" style="width: 180px; flex-shrink: 0; overflow: hidden;">
        <img class="cimg" src="{{img_url feature_image size='s'}}" alt="{{title}}" style="width: 100%; height: 100%; min-height: 130px; object-fit: cover; transition: transform 0.4s ease; display: block;" loading="lazy">
    </div>
    <div style="padding: 20px 22px; display: flex; flex-direction: column; justify-content: center; flex: 1;">
        <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 8px; flex-wrap: wrap;">
            {{#if primary_tag}}<span class="pill">{{primary_tag.name}}</span>{{/if}}
            <span class="sans" style="font-size: 12px; color: #6B7E8C;">{{date format="MMM YYYY"}}</span>
            <span class="sans" style="font-size: 12px; color: #6B7E8C;">{{reading_time}}</span>
        </div>
        <h3 class="serif" style="font-size: 18px; font-weight: 700; line-height: 1.3; color: #111820; margin-bottom: 10px;">{{title}}</h3>
        {{#if excerpt}}<p class="sans" style="font-size: 13px; color: #6B7E8C; line-height: 1.5; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{excerpt}}</p>{{/if}}
        <div class="sans" style="font-size: 13px; color: #D4A920; font-weight: 600;">Ler artigo →</div>
    </div>
</a>
{{else}}
<a href="{{url}}" class="post-row" style="text-decoration: none; color: inherit;">
    <div style="flex: 1;">
        <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 6px; flex-wrap: wrap;">
            {{#if primary_tag}}<span class="pill">{{primary_tag.name}}</span>{{/if}}
            <span class="sans" style="font-size: 12px; color: #6B7E8C;">{{date format="MMM YYYY"}}</span>
        </div>
        <h3 class="serif" style="font-size: 17px; font-weight: 700; line-height: 1.3; color: #111820;">{{title}}</h3>
    </div>
    <span class="post-arrow sans">→</span>
</a>
{{/if}}
